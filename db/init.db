  (2, 2, 2, 'reading', NOW() - INTERVAL '5 days', 150, 'Leyendo poco a poco.');

-- Préstamo de ejemplo (Ana -> Carlos del ejemplar GOT)
INSERT INTO loans (user_book_id, lender_user_id, borrower_user_id, borrower_name, loaned_at, due_date, returned_at, status, notes) VALUES
